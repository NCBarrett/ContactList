<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.VBox?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.control.ToggleButton?>
<?import javafx.scene.control.TitledPane?>
<?import javafx.scene.text.Text?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.AnchorPane?>
<VBox fx:id="root" alignment="CENTER" spacing="20.0" xmlns:fx="http://javafx.com/fxml"
      fx:controller="org.example.contactlist.Controller">
    <padding>
        <Insets bottom="20.0" top="20.0" left="10.0" right="10.0" />
    </padding>

<!--    <AnchorPane >-->
        <TableView fx:id="contactsTableView" />
<!--            AnchorPane.topAnchor="0.0"-->
<!--            AnchorPane.bottomAnchor="0.0"-->
<!--            AnchorPane.leftAnchor="0.0"-->
<!--            AnchorPane.rightAnchor="0.0" /> -->
<!--    </AnchorPane>-->

    <HBox fx:id="controlBtns">
        <ToggleButton fx:id="addToggle" text="Add" onAction="#addToggle"/>
        <ToggleButton fx:id="chgToggle" text="Edit" onAction="#chgToggle"/>
        <Button fx:id="deleteBtn" text="Remove" onAction="#handleDelBtn"/>
    </HBox>
    <HBox fx:id="addDetails" visible="false" managed="false" VBox.vgrow="NEVER">
        <VBox>
            <HBox>
                <Label fx:id="name" text="Name: "/>
                <TextField fx:id="nameField"/>
            </HBox>
            <HBox>
                <Label fx:id="phone" text="Ph: "/>
                <TextField fx:id="phoneField"/>
            </HBox>
            <HBox>
                <Label fx:id="email" text="Email: "/>
                <TextField fx:id="emailField"/>
            </HBox>
            <HBox>
                <Label fx:id="address" text="Address: "/>
                <TextField fx:id="addressField"/>
            </HBox>
        </VBox>
        <VBox alignment="CENTER"  >
            <Button fx:id="submitNew" text="Submit" onAction="#submitNew"/>
            <Button fx:id="submitChg" text="Submit changes" onAction="#submitChg" />
        </VBox>
    </HBox>
</VBox>